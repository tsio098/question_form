<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>質問予約 新都心校</title>

  <!-- LIFF SDK -->
  <script src="https://static.line-scdn.net/liff/edge/2/sdk.js"></script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      height: 100%;
      background: #1e3a5f;
      font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans JP', sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    /* ===== ローディング画面 ===== */
    #loadingScreen {
      position: fixed;
      inset: 0;
      background: linear-gradient(160deg, #152c47 0%, #1e3a5f 50%, #1a4a7a 100%);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 28px;
      z-index: 100;
      transition: opacity 0.4s ease;
    }
    #loadingScreen.fade-out { opacity: 0; pointer-events: none; }

    .logo-wrap {
      text-align: center;
    }
    .logo-icon {
      width: 72px; height: 72px;
      background: rgba(255,255,255,0.1);
      border-radius: 20px;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 14px;
      font-size: 2.2rem;
      border: 1.5px solid rgba(255,255,255,0.15);
    }
    .school-name {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.6);
      letter-spacing: 0.1em;
      margin-bottom: 4px;
    }
    .app-name {
      font-size: 1.25rem;
      font-weight: 700;
      color: #fff;
      letter-spacing: 0.04em;
    }

    /* スピナー */
    .spinner-wrap {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }
    .spinner {
      width: 36px; height: 36px;
      border: 3px solid rgba(255,255,255,0.2);
      border-top-color: #60a5fa;
      border-radius: 50%;
      animation: spin 0.75s linear infinite;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .loading-msg {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.04em;
    }

    /* ===== エラー画面 ===== */
    #errorScreen {
      display: none;
      position: fixed;
      inset: 0;
      background: linear-gradient(160deg, #152c47 0%, #1e3a5f 100%);
      align-items: center;
      justify-content: center;
      padding: 30px;
      z-index: 90;
    }
    #errorScreen.active { display: flex; }
    .error-card {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.15);
      border-radius: 16px;
      padding: 28px 24px;
      text-align: center;
      max-width: 320px;
      width: 100%;
    }
    .error-card .err-icon { font-size: 2.5rem; margin-bottom: 14px; }
    .error-card h2 { color: #fff; font-size: 1rem; margin-bottom: 8px; }
    .error-card p  { color: rgba(255,255,255,0.6); font-size: 0.85rem; line-height: 1.5; }

    /* ===== アプリ iframe（全画面） ===== */
    #appFrame {
      display: none;
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
    }
    #appFrame.active { display: block; }
  </style>
</head>
<body>

<!-- ローディング画面 -->
<div id="loadingScreen">
  <div class="logo-wrap">
    <div class="logo-icon">📝</div>
    <div class="school-name">GREAT VOYAGE 新都心校</div>
    <div class="app-name">質問予約フォーム</div>
  </div>
  <div class="spinner-wrap">
    <div class="spinner"></div>
    <div class="loading-msg">認証中...</div>
  </div>
</div>

<!-- エラー画面 -->
<div id="errorScreen">
  <div class="error-card">
    <div class="err-icon">⚠️</div>
    <h2 id="errorTitle">エラーが発生しました</h2>
    <p id="errorMsg">LINEアプリから開き直してください。</p>
  </div>
</div>

<!-- GAS アプリ iframe -->
<iframe id="appFrame" src="" allow="camera; microphone" sandbox="allow-scripts allow-forms allow-same-origin allow-popups"></iframe>

<script>
  // ============================================================
  // ★★★ 以下2つの値を必ず設定してください ★★★
  // ============================================================
  const LIFF_ID   = 'YOUR_LIFF_APP_ID';         // LINE Developersで取得したLIFF ID
  const GAS_URL   = 'https://script.google.com/macros/s/AKfycbxxxxz4bon9HCMeXyKImIMJcq0sQq_hYX7tw0UHrZqTzmPpnbvoD0afn4VQ53Uk9NG4xg/exec';       // 質問予約フォームのGAS WebアプリURL
  // ============================================================

  const loadingScreen = document.getElementById('loadingScreen');
  const errorScreen   = document.getElementById('errorScreen');
  const appFrame      = document.getElementById('appFrame');
  const loadingMsg    = document.querySelector('.loading-msg');

  function showError(title, msg) {
    loadingScreen.classList.add('fade-out');
    setTimeout(() => { loadingScreen.style.display = 'none'; }, 400);
    document.getElementById('errorTitle').textContent = title || 'エラー';
    document.getElementById('errorMsg').textContent   = msg   || 'もう一度お試しください。';
    errorScreen.classList.add('active');
  }

  function launchApp(userId) {
    loadingMsg.textContent = 'アプリを起動中...';
    const url = GAS_URL + '?lineUserId=' + encodeURIComponent(userId);
    appFrame.src = url;

    appFrame.onload = () => {
      loadingScreen.classList.add('fade-out');
      setTimeout(() => {
        loadingScreen.style.display = 'none';
        appFrame.classList.add('active');
      }, 400);
    };

    // 15秒でタイムアウト
    setTimeout(() => {
      if (!appFrame.classList.contains('active')) {
        showError('読み込みタイムアウト', 'アプリの読み込みに失敗しました。もう一度LINEアプリから開き直してください。');
      }
    }, 15000);
  }

  // ============================================================
  // LIFF 初期化
  // ============================================================
  liff.init({ liffId: LIFF_ID })
    .then(() => {
      if (!liff.isLoggedIn()) {
        // 未ログインの場合はLINEログインへリダイレクト
        liff.login({ redirectUri: location.href });
        return;
      }
      loadingMsg.textContent = 'ユーザー情報を取得中...';
      return liff.getProfile();
    })
    .then(profile => {
      if (!profile) return; // ログインリダイレクト中
      launchApp(profile.userId);
    })
    .catch(err => {
      console.error('LIFF Error:', err);
      if (err.code === 'INIT_FAILED') {
        showError('LIFF初期化エラー', 'LIFF IDの設定を確認してください。\nエラー: ' + err.message);
      } else {
        showError('認証エラー', 'LINEアプリから開き直してください。\nエラー: ' + err.message);
      }
    });
</script>
</body>
</html>
